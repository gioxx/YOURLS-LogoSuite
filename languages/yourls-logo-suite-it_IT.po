#: inc/admin-page.php
msgid "Branding Settings"
msgstr "Impostazioni branding"

#: inc/admin-page.php
msgid "Settings updated successfully!"
msgstr "Impostazioni salvate correttamente!"

#: inc/admin-page.php
msgid "Settings reset to default."
msgstr "Le impostazioni vengono riportate ai valori predefiniti."

#: inc/admin-page.php inc/update-check.php
msgid "YOURLS Logo Suite"
msgstr "YOURLS Logo Suite"

#: inc/admin-page.php
msgid "Version:"
msgstr "Versione:"

#: inc/admin-page.php
msgid "Page Title Settings"
msgstr "Impostazioni del titolo pagina"

#: inc/admin-page.php
msgid "Custom Title"
msgstr "Titolo personalizzato"

#: inc/admin-page.php
msgid "Example: your custom page title."
msgstr "Esempio: il titolo personalizzato da visualizzare nella pagina."

#: inc/admin-page.php
msgid "My YOURLS Panel"
msgstr "Il mio pannello YOURLS"

#: inc/admin-page.php
msgid "Keep \"(YOURLS)\" after the custom title"
msgstr "Mantieni \"(YOURLS)\" dopo il titolo personalizzato"

#: inc/admin-page.php
msgid "Logo Settings"
msgstr "Impostazioni logo"

#: inc/admin-page.php
msgid "Image URL"
msgstr "URL dell'immagine"

#: inc/admin-page.php
msgid "Example: a direct link to your logo image (PNG, JPG, SVG)."
msgstr "Esempio: un link diretto all'immagine del vostro logo (PNG, JPG, SVG)."

#: inc/admin-page.php
msgid "Upload image"
msgstr "Carica immagine"

#: inc/admin-page.php
msgid "Optional: upload PNG, JPG, GIF or WEBP from your computer (max 5 MB)."
msgstr "Opzionale: carica PNG, JPG, GIF o WEBP dal computer (max 5 MB)."

#: inc/admin-page.php
msgid "After selecting a file, click \"Save Settings\" to complete logo upload."
msgstr "Dopo aver selezionato un file, fai clic su \"Salva impostazioni\" per completare l'upload del logo."

#: inc/admin-page.php
msgid "ALT Tag"
msgstr "Tag ALT"

#: inc/admin-page.php
msgid "Example: descriptive text for accessibility."
msgstr "Esempio: testo descrittivo per l'accessibilità."

#: inc/admin-page.php
msgid "My Custom Logo"
msgstr "Il mio logo personalizzato"

#: inc/admin-page.php
msgid "Title Attribute"
msgstr "Attributo Title"

#: inc/admin-page.php
msgid "Example: tooltip text shown on hover."
msgstr "Esempio: testo mostrato al passaggio del mouse."

#: inc/admin-page.php
msgid "Back to Dashboard"
msgstr "Torna al pannello"

#: inc/admin-page.php
msgid "Back to top"
msgstr "Torna all'inizio"

#: inc/admin-page.php
msgid "Logo Preview"
msgstr "Anteprima logo"

#: inc/admin-page.php
msgid "Unable to load the image. Please check the URL."
msgstr "Impossibile caricare l'immagine. Controllare l'URL."

#: inc/admin-page.php
msgid "Width (px)"
msgstr "Larghezza (px)"

#: inc/admin-page.php
msgid "Height (px)"
msgstr "Altezza (px)"

#: inc/admin-page.php
msgid "Keep aspect ratio"
msgstr "Mantieni rapporto proporzioni"

#: inc/admin-page.php
msgid "Tip: set one side only and keep aspect ratio enabled for proportional resize."
msgstr "Suggerimento: imposta un solo lato e lascia attivo il rapporto proporzioni per un ridimensionamento proporzionale."

#: inc/admin-page.php
msgid "Notes"
msgstr "Note"

#: inc/admin-page.php
msgid "Save Settings"
msgstr "Salva impostazioni"

#: inc/admin-page.php
msgid "Saves the changes you made to logo and title."
msgstr "Salva le modifiche apportate al logo e al titolo."

#: inc/admin-page.php
msgid "Reset to Default"
msgstr "Ripristina impostazioni predefinite"

#: inc/admin-page.php
msgid "Restores original YOURLS logo and title, removing all customizations."
msgstr "Ripristina il logo e il titolo originali di YOURLS, rimuovendo tutte le personalizzazioni."

#: inc/admin-page.php
msgid "Are you sure you want to reset all settings?"
msgstr "Sei sicuro di voler ripristinare tutte le impostazioni?"

#: inc/admin-page.php
msgid "Logo image uploaded successfully. URL updated automatically."
msgstr "Immagine del logo caricata correttamente. URL aggiornato automaticamente."

#: inc/update-check.php
msgid "New version available:"
msgstr "Nuova versione disponibile:"

#: inc/update-check.php
msgid "View details on GitHub"
msgstr "Visualizza dettagli su GitHub"

#: inc/update-check.php
msgid "Update Available"
msgstr "Aggiornamento disponibile"

#: inc/helpers.php
msgid "Upload failed: no valid file received."
msgstr "Caricamento fallito: nessun file valido ricevuto."

#: inc/helpers.php
msgid "Upload failed: file is too large (max 5 MB)."
msgstr "Caricamento fallito: file troppo grande (max 5 MB)."

#: inc/helpers.php
msgid "Upload failed: unsupported image format. Allowed: PNG, JPG, GIF, WEBP."
msgstr "Caricamento fallito: formato immagine non supportato. Consentiti: PNG, JPG, GIF, WEBP."

#: inc/helpers.php
msgid "Upload failed: could not create upload directory."
msgstr "Caricamento fallito: impossibile creare la cartella di upload."

#: inc/helpers.php
msgid "Upload failed: upload directory is not writable."
msgstr "Caricamento fallito: la cartella di upload non è scrivibile."

#: inc/helpers.php
msgid "Upload failed while moving the file to destination."
msgstr "Caricamento fallito durante lo spostamento del file nella destinazione."
